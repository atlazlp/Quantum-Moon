#!/usr/bin/env python3
import os
import signal
import sys
import time

from evdev import InputDevice, UInput, ecodes

DEVICE = os.environ.get(
    "MIDDLE_MOUSE_DEVICE",
    "/dev/input/by-id/usb-E-Signal_USB_Gaming_Mouse-event-mouse",
)
DEBOUNCE_MS = int(os.environ.get("MIDDLE_MOUSE_DEBOUNCE_MS", "200"))
VIRTUAL_PRODUCT = int(os.environ.get("MIDDLE_MOUSE_VIRTUAL_PRODUCT", "0xA09E"), 0)


def main() -> None:
    dev = InputDevice(DEVICE)
    caps = dev.capabilities(absinfo=False)
    # Newer kernels / python-evdev reject EV_SYN codes when creating a UInput
    # device (OSError: [Errno 22] Invalid argument). UInput synthesises SYN
    # events itself, so strip it from the advertised capabilities. (This fix is
    # independent of the Hyprland version and must stay.)
    caps.pop(ecodes.EV_SYN, None)
    ui = UInput(
        events=caps,
        name=f"{dev.name} (debounced)",
        vendor=dev.info.vendor,
        product=VIRTUAL_PRODUCT,
        version=dev.info.version,
        bustype=dev.info.bustype,
        phys="debounced",
    )

    last_press = 0.0
    suppress_release = False

    def shutdown(*_: object) -> None:
        try:
            dev.ungrab()
        except Exception:
            pass
        sys.exit(0)

    signal.signal(signal.SIGTERM, shutdown)
    signal.signal(signal.SIGINT, shutdown)

    dev.grab()
    try:
        for event in dev.read_loop():
            if event.type == ecodes.EV_KEY and event.code == ecodes.BTN_MIDDLE:
                now = time.monotonic()
                if event.value == 1:
                    if (now - last_press) * 1000 < DEBOUNCE_MS:
                        suppress_release = True
                        continue
                    last_press = now
                    suppress_release = False
                elif event.value == 0 and suppress_release:
                    suppress_release = False
                    continue

            ui.write(event.type, event.code, event.value)
            if event.type == ecodes.EV_SYN and event.code == ecodes.SYN_REPORT:
                ui.syn()
    finally:
        try:
            dev.ungrab()
        except Exception:
            pass


if __name__ == "__main__":
    main()
