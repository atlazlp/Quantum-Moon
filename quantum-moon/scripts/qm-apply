#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
QM_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
STATE_DIR="${XDG_STATE_HOME:-${HOME}/.local/state}/quantum-moon"
CAELESTIA_STATE_DIR="${XDG_STATE_HOME:-${HOME}/.local/state}/caelestia"
SHELL_JSON="${HOME}/.config/caelestia/shell.json"
SCHEME_JSON="${CAELESTIA_STATE_DIR}/scheme.json"
HYPRPAPER_CONF="${HOME}/.config/hypr/hyprpaper.conf"
MODES_DIR="${QM_ROOT}/modes"
BASE_SCHEME="${QM_ROOT}/palettes/base-scheme.json"

# shellcheck source=qm-video-lib.sh
source "${SCRIPT_DIR}/qm-video-lib.sh"

list_slugs() {
  find "${MODES_DIR}" -mindepth 1 -maxdepth 1 -type d -printf '%f\n' | LC_ALL=C sort
}

write_hyprpaper_conf() {
  local pairs_json="$1"
  {
    echo "splash = false"
    echo
    echo "# Generated by quantum-moon qm-apply ($(date -Iseconds))"
    echo
    local i=0
    while true; do
      local name path
      name="$(echo "${pairs_json}" | jq -r ".[${i}].name // empty")"
      path="$(echo "${pairs_json}" | jq -r ".[${i}].path // empty")"
      [[ -z "${name}" || "${name}" == "null" ]] && break
      echo "wallpaper {"
      echo "    monitor = ${name}"
      echo "    path = ${path}"
      echo "    fit_mode = cover"
      echo "}"
      echo
      i=$((i + 1))
    done
  } >"${HYPRPAPER_CONF}.tmp"
  mv "${HYPRPAPER_CONF}.tmp" "${HYPRPAPER_CONF}"
}

write_scheme() {
  local palette="$1"
  [[ -f "${BASE_SCHEME}" ]] || { echo "Missing base scheme: ${BASE_SCHEME}" >&2; exit 1; }
  [[ -f "${palette}" ]] || { echo "Missing palette: ${palette}" >&2; exit 1; }

  mkdir -p "${CAELESTIA_STATE_DIR}"
  local tmp
  tmp="$(mktemp "${SCHEME_JSON}.tmp.XXXXXX")"
  jq -s '.[0] * .[1]' "${BASE_SCHEME}" "${palette}" >"${tmp}"
  mv "${tmp}" "${SCHEME_JSON}"
}

record_random_walk_history() {
  local slug="$1"
  mkdir -p "${STATE_DIR}"
  local f="${STATE_DIR}/random-walk.json"
  if [[ ! -f "${f}" ]]; then
    printf '%s\n' '{"history":[]}' >"${f}"
  fi
  local tmp
  tmp="$(mktemp "${STATE_DIR}/.random-walk.XXXXXX")"
  jq --arg s "${slug}" '.history += [$s] | .history |= .[-50:]' "${f}" >"${tmp}" && mv "${tmp}" "${f}"
}

apply_slug() {
  local slug="$1"
  local prev_slug=""
  if [[ -f "${STATE_DIR}/current.json" ]]; then
    prev_slug="$(jq -r '.slug // empty' "${STATE_DIR}/current.json" 2>/dev/null || true)"
  fi
  local mode_dir="${MODES_DIR}/${slug}"
  local meta="${mode_dir}/meta.json"
  [[ -f "${meta}" ]] || { echo "Unknown mode: ${slug}" >&2; exit 1; }

  local display
  display="$(jq -r '.displayName // .slug' "${meta}")"

  qm_video_stop

  local monitors_json
  if ! monitors_json="$(hyprctl monitors -j 2>/dev/null)"; then
    echo "hyprctl failed (Hyprland not running?)" >&2
    exit 1
  fi

  local sorted
  sorted="$(echo "${monitors_json}" | jq -c 'sort_by(.x, .y)')"

  local use_center_video=0
  if [[ -f "${mode_dir}/wallpapers/center.mp4" ]] && command -v mpvpaper >/dev/null 2>&1; then
    use_center_video=1
  fi
  local center_idx
  center_idx="$(qm_center_slot_index)"

  local pairs='[]'
  local count max i=0
  count="$(echo "${sorted}" | jq -r 'length // 0')"
  [[ "${count}" =~ ^[0-9]+$ ]] || count=0
  max="${count}"
  [[ "${max}" -gt 3 ]] && max=3
  while [[ "${i}" -lt "${max}" ]]; do
    local mon wp abs
    mon="$(echo "${sorted}" | jq -r ".[${i}].name")"
    wp="${mode_dir}/wallpapers/slot-${i}.png"
    [[ -f "${wp}" ]] || { echo "Missing wallpaper: ${wp} (run qm-init-mvp-assets)" >&2; exit 1; }
    abs="$(realpath "${wp}")"
    pairs="$(echo "${pairs}" | jq -c --arg n "${mon}" --arg p "${abs}" '. + [{name: $n, path: $p}]')"
    if [[ "${use_center_video}" -eq 1 ]] && [[ "${i}" -eq "${center_idx}" ]]; then
      i=$((i + 1))
      continue
    fi
    hyprctl hyprpaper preload "${abs}" >/dev/null 2>&1 || true
    hyprctl hyprpaper wallpaper "${mon},${abs}" >/dev/null 2>&1 || true
    i=$((i + 1))
  done

  local conf_pairs="${pairs}"
  if [[ "${use_center_video}" -eq 1 ]]; then
    local center_mon
    center_mon="$(echo "${sorted}" | jq -r ".[${center_idx}] | .name // empty")"
    if [[ -n "${center_mon}" ]]; then
      conf_pairs="$(echo "${conf_pairs}" | jq -c --arg n "${center_mon}" '[.[] | select(.name != $n)]')"
    fi
  fi
  write_hyprpaper_conf "${conf_pairs}"

  local logo
  logo="${mode_dir}/logo.png"
  [[ -f "${logo}" ]] || { echo "Missing logo: ${logo}" >&2; exit 1; }
  local logo_abs
  logo_abs="$(realpath "${logo}")"
  [[ -f "${SHELL_JSON}" ]] || { echo "Missing ${SHELL_JSON}" >&2; exit 1; }
  local tmp
  tmp="$(mktemp)"
  jq --arg l "${logo_abs}" '.general.logo = $l' "${SHELL_JSON}" >"${tmp}"
  mv "${tmp}" "${SHELL_JSON}"

  write_scheme "${mode_dir}/palette.json"
  if ! python3 "${SCRIPT_DIR}/qm-sync-file-manager-theme.py" "${SCHEME_JSON}"; then
    echo "quantum-moon: qm-sync-file-manager-theme.py failed (GTK/Nautilus/kitty/Qt sync skipped)" >&2
  fi

  mkdir -p "${STATE_DIR}"
  jq -n --arg slug "${slug}" --arg dn "${display}" '{slug: $slug, displayName: $dn}' >"${STATE_DIR}/current.json"

  if [[ "${prev_slug}" != "${slug}" ]]; then
    record_random_walk_history "${slug}"
  fi

  sleep 0.35
  "${SCRIPT_DIR}/qm-video-restart" "${slug}" || true
}

slug="${1:-}"
if [[ "${slug}" == "--persisted" ]]; then
  if [[ -f "${STATE_DIR}/current.json" ]]; then
    slug="$(jq -r '.slug' "${STATE_DIR}/current.json")"
  else
    slug="eye-of-the-universe"
  fi
fi

if [[ -z "${slug}" ]]; then
  echo "usage: qm-apply <slug>|--persisted" >&2
  echo "modes: $(list_slugs | tr '\n' ' ')" >&2
  exit 1
fi

apply_slug "${slug}"
