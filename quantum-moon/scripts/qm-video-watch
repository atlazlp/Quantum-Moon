#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
# shellcheck source=qm-video-lib.sh
source "${SCRIPT_DIR}/qm-video-lib.sh"

last=""
sock="$(qm_video_sock)"

sync_pause() {
  local want sock
  sock="$(qm_video_sock)"
  [[ -S "${sock}" ]] || { last=""; return 0; }

  if qm_desktop_visible_on_center; then
    want="false"
  else
    want="true"
  fi

  if [[ "${want}" != "${last}" ]]; then
    qm_mpv_set_pause "${sock}" "${want}" && last="${want}" || last=""
  fi
}

while true; do
  if ! hyprctl monitors -j >/dev/null 2>&1; then
    sleep 2
    continue
  fi
  sync_pause
  sleep 0.25
done
